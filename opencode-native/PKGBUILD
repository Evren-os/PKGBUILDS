# Maintainer: evrenos

pkgname=opencode-native
_pkgname=opencode
pkgver=1.3.15
pkgrel=1
pkgdesc='The open source coding agent (native x86_64 build from source)'
arch=('x86_64')
url='https://github.com/anomalyco/opencode'
license=('MIT')
depends=(
  'curl'
  'gcc-libs'
  'glibc'
  'icu'
  'ripgrep'
  'tar'
)
makedepends=(
  'bun>=1.3.9'
  'git'
)
optdepends=(
  'wl-clipboard: clipboard support on Wayland'
  'xclip: clipboard support on X11'
)
provides=("opencode=${pkgver}")
conflicts=(
  'opencode'
  'opencode-bin'
  'opencode-git'
)
options=(
  '!debug'
  '!strip'
)

_commit='930e94a3ea098b9d56fcb6d08b545256d2546a82'
source=("${_pkgname}::git+${url}.git#commit=${_commit}")
b2sums=('SKIP')

prepare() {
  cd "${_pkgname}"
  # HUSKY=0 bun install --frozen-lockfile
  bun install --frozen-lockfile --ignore-scripts
}

build() {
  cd "${_pkgname}/packages/opencode"

  export CFLAGS="${CFLAGS} -march=native -mtune=native -O3"
  export CXXFLAGS="${CXXFLAGS} -march=native -mtune=native -O3"
  export RUSTFLAGS="${RUSTFLAGS:+${RUSTFLAGS} }-C target-cpu=native -C opt-level=3"

  OPENCODE_VERSION="${pkgver}" bun run ./script/build.ts --single --skip-install
}

check() {
  cd "${_pkgname}/packages/opencode"
  ./dist/opencode-linux-x64/bin/opencode --version >/dev/null 2>&1
}

package() {
  cd "${_pkgname}"

  install -vDm755 -t "${pkgdir}/usr/bin" "packages/opencode/dist/opencode-linux-x64/bin/opencode"
  install -vDm644 -t "${pkgdir}/usr/share/licenses/${pkgname}" LICENSE

  SHELL=/bin/bash "${pkgdir}/usr/bin/opencode" completion \
    | install -vDm644 /dev/stdin "${pkgdir}/usr/share/bash-completion/completions/opencode"
  SHELL=/bin/zsh "${pkgdir}/usr/bin/opencode" completion \
    | install -vDm644 /dev/stdin "${pkgdir}/usr/share/zsh/site-functions/_opencode"
}