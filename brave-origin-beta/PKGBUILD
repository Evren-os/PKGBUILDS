# Maintainer: Evren-os

pkgname=brave-origin-beta
pkgver=1.93.117
pkgrel=1
pkgdesc='The minimalist browser from the makers of Brave (beta release)'
arch=(x86_64)
url='https://brave.com/origin/download-beta'
license=(MPL-2.0 BSD-3-Clause LicenseRef-chromium)
depends=(
    alsa-lib
    gtk3
    libxss
    nss
    ttf-font
)
optdepends=(
    'cups: Printer support'
    'libgnome-keyring: GNOME keyring support'
    'libnotify: Native notification support'
    'mesa: Hardware-accelerated rendering'
)
provides=(brave-origin-beta-bin)
conflicts=(brave-origin-beta-bin)
options=(!strip)

_filename="${pkgname}-${pkgver}-linux-amd64.zip"
_sha256zip='3d4cf677992d1db11b9386a904470446175e42ea516e33555109550dafb032d1'

source=(
    "${pkgname}.sh"
    "${pkgname}.desktop"
    "${_filename}::https://github.com/brave/brave-browser/releases/download/v${pkgver}/${_filename}"
)
noextract=("${_filename}")
sha256sums=(
    '6afbc253d899aa6fbe5dcbe082f8137824f422fe169c4e95fec6334893925fb0'
    '3fd2e0f9055ff73c2200a668627b70e9c46652d39f30e9077706d25caf8226f1'
    "${_sha256zip}"
)

prepare() {
    mkdir -p "${pkgname}"
    bsdtar -xf "${_filename}" -C "${pkgname}"
    chmod +x "${pkgname}/brave"
    rm -rf "${pkgname}/cron"
    rm -f "${pkgname}/${pkgname}"
}

package() {
    install -dm0755 "${pkgdir}/opt/${pkgname}"
    cp -a "${pkgname}/." "${pkgdir}/opt/${pkgname}/"

    chmod 4755 "${pkgdir}/opt/${pkgname}/chrome-sandbox"

    install -Dm0755 "${pkgname}.sh" "${pkgdir}/usr/bin/${pkgname}"
    install -Dm0644 "${pkgname}.desktop" "${pkgdir}/usr/share/applications/${pkgname}.desktop"
    install -Dm0644 -t "${pkgdir}/usr/share/licenses/${pkgname}/" "${pkgname}/LICENSE"

    for size in 16 24 32 48 64 128 256; do
        install -Dm0644 "${pkgname}/product_logo_${size}_beta.png" \
            "${pkgdir}/usr/share/icons/hicolor/${size}x${size}/apps/brave_origin_beta.png"
    done
}
